# linear-agent-mini environment (Bun auto-loads .env — copy this to .env, mode 0600).
# Do NOT set ANTHROPIC_API_KEY: the Agent SDK falls back to the dedicated user's Claude
# subscription login (~/.claude/.credentials.json). See ops/setup.md.

# ── Seam: callback to Vercel (contract §6) ─────────────────────────────
VERCEL_CALLBACK_URL=https://your-app.vercel.app/api/mini/callback
CALLBACK_SECRET=                 # bearer presented on the callback; MUST match Vercel

# ── App-layer auth (REQUIRED) ──────────────────────────────────────────
# Shared bearer Vercel must present on EVERY mini request. The mini fails CLOSED: if this is
# unset, every endpoint returns 401. MUST match MINI_AUTH_SECRET on the Vercel side.
MINI_AUTH_SECRET=

# ── Seam: Cloudflare Access defense-in-depth (optional) ────────────────
# Cloudflare enforces these at the edge; set ENFORCE_CF_ACCESS=1 to also check them here.
# When enforced, the mini fails CLOSED if the id/secret below are unset.
ENFORCE_CF_ACCESS=0
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# ── Linear (streamed activities) ──────────────────────────────────────
LINEAR_ACCESS_TOKEN=
LINEAR_API_URL=https://api.linear.app/graphql

# ── GitHub (push + PR) ────────────────────────────────────────────────
GITHUB_TOKEN=                    # repo-scoped PAT
GITHUB_API_URL=https://api.github.com
PR_BASE_BRANCH=main

# ── Workspace / repo ──────────────────────────────────────────────────
WORK_ROOT=/Users/linearagent/work
DEFAULT_REPO_URL=git@github.com:org/repo.git
# DB_PATH defaults to $WORK_ROOT/mini.sqlite

# ── Concurrency ───────────────────────────────────────────────────────
MAX_CONCURRENT_EXECUTIONS=2
MAX_CONCURRENT_PLANS=3

# ── Timeouts / heartbeats (ms) ────────────────────────────────────────
HEARTBEAT_INTERVAL_MS=1200000    # < 30 min stale window
ACTIVITY_THROTTLE_MS=1500

# ── Server ────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info                   # set to "debug" for verbose logs

# ── Dry-run / feature flags (default off) ─────────────────────────────
DRY_RUN=0                        # skip the SDK; run a fast fake job (seam smoke test)
LINEAR_DRY_RUN=0                 # log Linear calls instead of POSTing
PR_DRY_RUN=0                     # synthesize a PR url/branch instead of pushing
USE_CONTAINER=0                  # NOT wired yet: execute runs IN-PROCESS on the host regardless.
                                 # Only run execute jobs on a trusted machine until this lands.
